# Production/preview database.
# Recommended: Supabase PostgreSQL pooled connection URL for Vercel runtime.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct database URL for Prisma migrations/db push.
# Recommended: Supabase direct connection URL.
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Never commit real secrets.
# Use a strong random value of at least 32 characters in production.
AI_LINKER_ENCRYPTION_KEY="replace-with-strong-random-key"
ADMIN_SESSION_SECRET="replace-with-strong-random-session-secret"

# Admin login bootstrap values.
# Generate ADMIN_PASSWORD_HASH with: npm run admin:hash-password -- "your-strong-password"
# Or run without an argument to generate a random password and hash.
ADMIN_EMAIL="admin@ai-linker.local"
ADMIN_NAME="AI Linker Admin"
ADMIN_PASSWORD_HASH="replace-with-sha256-password-hash"
